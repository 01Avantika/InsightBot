# InsightBot Environment Configuration
# Copy this file to .env and fill in your API keys

# ── LLM Configuration (choose one or both) ────────────────────────────────────
# OpenAI GPT (recommended for best results)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (alternative)
# GOOGLE_API_KEY=AIza-your-google-api-key-here

# ── Optional: Ollama (local LLM) ──────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── App Configuration ──────────────────────────────────────────────────────────
APP_SECRET=change-this-to-a-random-secret-string
MAX_UPLOAD_MB=100
